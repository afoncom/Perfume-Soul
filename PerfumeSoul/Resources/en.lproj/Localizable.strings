"profileDescription.sun.aquarius" = "Your core is independent, conceptual, and future-facing. You need originality and room to think differently.";
"profileDescription.sun.aries" = "You move through life with initiative, speed, and a need to act before the moment cools down.";
"profileDescription.sun.cancer" = "Your center is protective and intuitive. You notice emotional atmosphere and value safety before exposure.";
"profileDescription.sun.capricorn" = "Your identity is disciplined and long-range. You respect competence, consistency, and visible results.";
"profileDescription.sun.gemini" = "Your identity is curious, mobile, and verbal. You need variety, ideas, and a sense of mental freshness.";
"profileDescription.sun.leo" = "Your core is expressive, warm, and creative. You need space to show individuality and be seen sincerely.";
"profileDescription.sun.libra" = "Your core seeks beauty, balance, and thoughtful connection. You read social tone quickly and value harmony.";
"profileDescription.sun.pisces" = "Your identity is sensitive, imaginative, and porous. You absorb mood easily and move well through symbols.";
"profileDescription.sun.sagittarius" = "Your core is expansive, direct, and freedom-seeking. You need meaning, movement, and a wider horizon.";
"profileDescription.sun.scorpio" = "Your identity is intense, private, and transformative. You prefer depth over surface-level impressions.";
"profileDescription.sun.taurus" = "Your core is steady, sensual, and grounded. You value comfort, loyalty, and things that feel real.";
"profileDescription.sun.virgo" = "Your identity is precise, observant, and improvement-oriented. You feel strong when life has useful structure.";
"profileDescription.synthesis.alignedInner.description" = "Your conscious style and emotional needs are close to each other. You usually understand what you want and recover faster when your environment matches your natural pace.";
"profileDescription.synthesis.alignedInner.summary" = "Your inner world is steady: %@ defines both your direction and emotional tone.";
"profileDescription.synthesis.alignedInner.title" = "Aligned inner rhythm";
"profileDescription.synthesis.balanced.description" = "Your placements do not push one temperament too strongly. This makes your profile flexible and easier to adapt to different people and contexts.";
"profileDescription.synthesis.balanced.summary" = "Your chart is balanced, so the full combination matters more than one dominant trait.";
"profileDescription.synthesis.balanced.title" = "Balanced profile";
"profileDescription.synthesis.clearOuter.description" = "Your Ascendant supports your Sun, so your first impression usually matches your main direction. The Moon adds a more private emotional layer.";
"profileDescription.synthesis.clearOuter.summary" = "People often read your main energy quickly, while your emotional world has more nuance.";
"profileDescription.synthesis.clearOuter.title" = "Clear outer expression";
"profileDescription.synthesis.creativeContrast.description" = "Your Sun and Moon pull from different temperaments. This can create depth: one part of you wants to move one way, while another needs a different kind of safety.";
"profileDescription.synthesis.creativeContrast.summary" = "Your profile has contrast, so your strongest choices often combine confidence with self-awareness.";
"profileDescription.synthesis.creativeContrast.title" = "Creative inner contrast";
"profileDescription.synthesis.elementSignature.description" = "All three core placements support the same element. This gives your profile a strong, consistent temperament and makes your preferences easier to recognize.";
"profileDescription.synthesis.elementSignature.summary" = "Your chart is strongly %@, so your personality reads as focused and consistent.";
"profileDescription.synthesis.elementSignature.title" = "%@ signature";
